          echo "- **Version:** ${{ needs.build-and-test.outputs.version }}" >> "$GITHUB_STEP_SUMMARY"
          echo "- **Commit:** ${{ github.sha }}" >> "$GITHUB_STEP_SUMMARY"
          echo "- **Agent image:** ${{ env.AGENT_IMAGE }}:staging" >> "$GITHUB_STEP_SUMMARY"
          echo "- **Server image:** ${{ env.SERVER_IMAGE }}:staging" >> "$GITHUB_STEP_SUMMARY"
</file>

<file path=".github/workflows/nightly.yml">
name: Nightly Quality

on:
  schedule:
    - cron: "0 3 * * *"
  workflow_dispatch:

permissions:
  contents: read

jobs:
  vet:
    name: Go Vet
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - uses: actions/setup-go@v6
        with:
          go-version: "1.26"
          cache: true
      - run: go vet ./...

  lint:
    name: Lint
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - uses: actions/setup-go@v6
        with:
          go-version: "1.26"
          cache: true
      - uses: golangci/golangci-lint-action@v6
        with:
          version: latest

  test:
    name: Test with Coverage
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - uses: actions/setup-go@v6
        with:
          go-version: "1.26"
          cache: true
      - name: Run tests
        run: go test -v -race -coverprofile=coverage.out ./...
      - name: Coverage summary
        run: |
          echo "## Nightly Test Coverage" >> "$GITHUB_STEP_SUMMARY"
          echo '```' >> "$GITHUB_STEP_SUMMARY"
          go tool cover -func=coverage.out >> "$GITHUB_STEP_SUMMARY"
          echo '```' >> "$GITHUB_STEP_SUMMARY"

  build:
    name: Full Cross-compilation
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - uses: actions/setup-go@v6
        with:
          go-version: "1.26"
          cache: true
      - name: Build all platforms
        run: make build-all

  security:
    name: Security Audit
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - uses: actions/setup-go@v6
        with:
          go-version: "1.26"
          cache: true
      - name: Install govulncheck
        run: go install golang.org/x/vuln/cmd/govulncheck@latest
      - name: Run govulncheck
        run: govulncheck ./...

  outdated-deps:
    name: Outdated Dependencies
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - uses: actions/setup-go@v6
        with:
          go-version: "1.26"
          cache: true
      - name: Check for updates
        run: |
          echo "## Dependency Update Report" >> "$GITHUB_STEP_SUMMARY"
          echo '```' >> "$GITHUB_STEP_SUMMARY"
          go list -u -m all 2>&1 | grep '\[' >> "$GITHUB_STEP_SUMMARY" || echo "All dependencies are up to date" >> "$GITHUB_STEP_SUMMARY"
          echo '```' >> "$GITHUB_STEP_SUMMARY"
</file>

<file path=".github/workflows/update-context.yml">
# Managed by CISECSL/org-tools — update via bootstrap-org.sh
# Self-contained: no external repo access required
name: Update Context

on:
  push:
    branches: [main, dev]
    paths-ignore:
      - '.claude/context.md'
      - '.claude/repomix.xml'
  workflow_dispatch:

concurrency:
  group: update-context-${{ github.ref }}
  cancel-in-progress: true

jobs:
  update-context:
    name: Generate context.md & Sync to Notion
    runs-on: ubuntu-latest
    timeout-minutes: 10
    permissions:
      contents: write

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Generate context.md
        env:
          REPO_NAME: ${{ github.event.repository.name }}
          REPO_DESCRIPTION: ${{ github.event.repository.description }}
        run: |
          set -euo pipefail
          REPO_ROOT="$(pwd)"
          OUTPUT_DIR=".claude"
          OUTPUT_FILE="$OUTPUT_DIR/context.md"
          TIMESTAMP="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

          has_file() { [ -f "$REPO_ROOT/$1" ]; }
          has_dir()  { [ -d "$REPO_ROOT/$1" ]; }
          jq_file()  { jq -r "$2" "$REPO_ROOT/$1" 2>/dev/null || echo ""; }
          has_dep()  { echo "$1" | grep -qxF "$2"; }

          FILE_COUNT=$(find "$REPO_ROOT" -maxdepth 1 -not -name '.git' -not -name '.' | wc -l | tr -d ' ')
          if [ "$FILE_COUNT" -lt 3 ]; then echo "Repo empty, skipping."; exit 0; fi

          # Overview
          OVERVIEW=""
          if has_file "README.md"; then
            OVERVIEW=$(awk '/^#/{if(found_heading)exit;found_heading=1;next}found_heading&&/^\[!\[/{next}found_heading&&/^!\[/{next}found_heading&&/^</{next}found_heading&&/^$/&&got_content{exit}found_heading&&/\S/{got_content=1;print}found_heading&&/^$/&&!got_content{next}' "$REPO_ROOT/README.md" | head -5)
          fi
          [ -z "$OVERVIEW" ] && has_file "package.json" && OVERVIEW=$(jq_file "package.json" '.description // empty')
          [ -z "$OVERVIEW" ] && has_file "pyproject.toml" && OVERVIEW=$(grep -m1 'description' "$REPO_ROOT/pyproject.toml" 2>/dev/null | sed 's/.*=\s*"\(.*\)"/\1/' || true)
          [ -z "$OVERVIEW" ] && OVERVIEW="${REPO_DESCRIPTION:-No description available.}"

          # Tech stack
          LANGUAGES=(); FRAMEWORKS=(); BUILD_TOOLS=(); DATABASES=(); INFRA=()
          DEPS=""; DEV_DEPS=""; ALL_DEPS=""

          if has_file "package.json"; then
            LANGUAGES+=("JavaScript/TypeScript")
            DEPS=$(jq_file "package.json" '(.dependencies // {}) | keys[]')
            DEV_DEPS=$(jq_file "package.json" '(.devDependencies // {}) | keys[]')
            ALL_DEPS=$(printf '%s\n%s' "$DEPS" "$DEV_DEPS")
            has_dep "$ALL_DEPS" "typescript" && LANGUAGES=("TypeScript") || true
            has_dep "$DEPS" "react"        && FRAMEWORKS+=("React")   || true
            has_dep "$DEPS" "next"         && FRAMEWORKS+=("Next.js") || true
            has_dep "$DEPS" "vue"          && FRAMEWORKS+=("Vue")     || true
            has_dep "$DEPS" "svelte"       && FRAMEWORKS+=("Svelte")  || true
            has_dep "$DEPS" "express"      && FRAMEWORKS+=("Express") || true
            has_dep "$DEPS" "fastify"      && FRAMEWORKS+=("Fastify") || true
            has_dep "$DEPS" "@nestjs/core" && FRAMEWORKS+=("NestJS")  || true
            has_dep "$DEPS" "hono"         && FRAMEWORKS+=("Hono")    || true
            has_dep "$ALL_DEPS" "vite"     && BUILD_TOOLS+=("Vite")   || true
            has_dep "$ALL_DEPS" "webpack"  && BUILD_TOOLS+=("webpack")|| true
            has_dep "$ALL_DEPS" "turbo"    && BUILD_TOOLS+=("Turborepo") || true
            has_dep "$DEPS" "@supabase/supabase-js" && DATABASES+=("Supabase")    || true
            has_dep "$ALL_DEPS" "prisma"            && DATABASES+=("Prisma")      || true
            has_dep "$DEPS" "mongoose"              && DATABASES+=("MongoDB")     || true
            has_dep "$DEPS" "pg"                    && DATABASES+=("PostgreSQL")  || true
            has_dep "$DEPS" "mysql2"                && DATABASES+=("MySQL")       || true
            has_dep "$DEPS" "redis"                 && DATABASES+=("Redis")       || true
            has_dep "$ALL_DEPS" "tailwindcss"       && INFRA+=("Tailwind CSS")    || true
            has_dep "$DEPS" "@mui/material"         && INFRA+=("Material UI")     || true
          fi
          if has_file "requirements.txt" || has_file "pyproject.toml" || has_file "setup.py"; then
            LANGUAGES+=("Python")
            PY=$(cat "$REPO_ROOT/requirements.txt" "$REPO_ROOT/pyproject.toml" 2>/dev/null || true)
            echo "$PY" | grep -qi 'django'   && FRAMEWORKS+=("Django")   || true
            echo "$PY" | grep -qi 'flask'    && FRAMEWORKS+=("Flask")    || true
            echo "$PY" | grep -qi 'fastapi'  && FRAMEWORKS+=("FastAPI")  || true
          fi
          has_file "go.mod"    && LANGUAGES+=("Go")   || true
          has_file "Cargo.toml"&& LANGUAGES+=("Rust") || true
          has_file "Dockerfile"                        && INFRA+=("Docker")         || true
          { has_file "docker-compose.yml" || has_file "docker-compose.yaml"; } && INFRA+=("Docker Compose") || true
          has_dir  "supabase"                          && INFRA+=("Supabase")       || true
          has_dir  ".github/workflows"                 && INFRA+=("GitHub Actions") || true
          has_dir  "terraform"                         && INFRA+=("Terraform")      || true

          fmt() { [ ${#@} -eq 0 ] && echo "None detected" || printf '%s\n' "$@" | sort -u | paste -sd',' | sed 's/,/, /g'; }
          LANG_STR=$(fmt "${LANGUAGES[@]}" 2>/dev/null || echo "Unknown")
          FRMK_STR=$(fmt "${FRAMEWORKS[@]}" 2>/dev/null || echo "None detected")
          BILD_STR=$(fmt "${BUILD_TOOLS[@]}" 2>/dev/null || echo "None detected")
          DB_STR=$(fmt "${DATABASES[@]}" 2>/dev/null || echo "None detected")
          INFRA_STR=$(fmt "${INFRA[@]}" 2>/dev/null || echo "None detected")

          # Commands
          COMMANDS=""
          if has_file "package.json"; then
            SCRIPTS=$(jq_file "package.json" '.scripts // {} | to_entries[] | select(.key | test("^(dev|build|start|lint|test|test:unit|test:e2e|test:integration|deploy|db:|setup:|seed:|prepare)")) | "| `\(.key)` | `\(.value)` |"')
            [ -n "$SCRIPTS" ] && COMMANDS="### npm scripts\n\n| Script | Command |\n|---|---|\n$SCRIPTS"
          fi
          if has_file "Makefile"; then
            MAKE_TARGETS=$(grep -E '^[a-zA-Z_-]+:' "$REPO_ROOT/Makefile" 2>/dev/null | sed 's/:.*//' | head -20 || true)
            if [ -n "$MAKE_TARGETS" ]; then
              MAKE_TABLE=""
              while IFS= read -r t; do
                [ -z "$t" ] && continue
                D=$(grep -B1 "^${t}:" "$REPO_ROOT/Makefile" 2>/dev/null | grep '^##' | sed 's/^##\s*//' || echo "")
                MAKE_TABLE="$MAKE_TABLE\n| \`make $t\` | $D |"
              done <<< "$MAKE_TARGETS"
              COMMANDS="$COMMANDS\n\n### Makefile targets\n\n| Command | Description |\n|---|---|$MAKE_TABLE"
            fi
          fi

          # Directory structure
          IGNORED=".git|node_modules|dist|build|.next|__pycache__|.venv|venv|env|target|vendor|.cache|coverage"
          DIR_TREE=""
          for dir in "$REPO_ROOT"/*/; do
            [ -d "$dir" ] || continue
            dn=$(basename "$dir")
            echo "$dn" | grep -qE "^($IGNORED)$" && continue
            ANN=""
            case "$dn" in
              src) ANN="Source code" ;; lib) ANN="Library code" ;; app) ANN="Application code" ;;
              pages) ANN="Page components" ;; api) ANN="API endpoints" ;; components) ANN="UI components" ;;
              hooks) ANN="React hooks" ;; utils|helpers) ANN="Utilities" ;; types) ANN="Type definitions" ;;
              stores|store) ANN="State management" ;; tests|test|__tests__) ANN="Test suite" ;;
              e2e|cypress|playwright) ANN="E2E tests" ;; docs) ANN="Documentation" ;;
              scripts) ANN="Build/deploy scripts" ;; migrations) ANN="Database migrations" ;;
              supabase) ANN="Supabase config & edge functions" ;; public|static) ANN="Static assets" ;;
              .github) ANN="GitHub Actions" ;; .claude) ANN="Claude Code config" ;;
              deploy|deployment) ANN="Deployment configs" ;;
            esac
            [ -n "$ANN" ] && DIR_TREE="$DIR_TREE\n├── $dn/ — $ANN" || DIR_TREE="$DIR_TREE\n├── $dn/"
            if [ "$dn" = "src" ] || [ "$dn" = "app" ] || [ "$dn" = "lib" ]; then
              for sub in "$dir"*/; do
                [ -d "$sub" ] || continue
                sn=$(basename "$sub")
                echo "$sn" | grep -qE "^($IGNORED)$" && continue
                SANN=""
                case "$sn" in
                  components) SANN="UI components" ;; hooks) SANN="React hooks" ;;
                  utils|helpers) SANN="Utilities" ;; types) SANN="Type definitions" ;;
                  stores|store) SANN="State management" ;; pages) SANN="Page components" ;;
                  api) SANN="API layer" ;; services) SANN="Service layer" ;;
                  styles|css) SANN="Styles" ;; i18n|locales) SANN="Internationalization" ;;
                  integrations) SANN="Third-party integrations" ;; test|tests|__tests__) SANN="Tests" ;;
                esac
                [ -n "$SANN" ] && DIR_TREE="$DIR_TREE\n│   ├── $sn/ — $SANN" || DIR_TREE="$DIR_TREE\n│   ├── $sn/"
              done
            fi
          done

          # Key files
          KEY_FILES=""
          declare -A FDESC=(
            ["CLAUDE.md"]="Claude Code instructions" ["README.md"]="Project documentation"
            ["Dockerfile"]="Docker container" ["docker-compose.yml"]="Docker Compose"
            ["Makefile"]="Build automation" ["tsconfig.json"]="TypeScript config"
            ["vite.config.ts"]="Vite config" ["tailwind.config.ts"]="Tailwind config"
            ["eslint.config.js"]="ESLint config" ["vitest.config.ts"]="Vitest config"
            ["playwright.config.ts"]="Playwright config" [".env.example"]="Env template"
            ["supabase/config.toml"]="Supabase config"
          )
          for f in "${!FDESC[@]}"; do
            has_file "$f" && KEY_FILES="$KEY_FILES\n| \`$f\` | ${FDESC[$f]} |" || true
          done
          if has_dir ".github/workflows"; then
            WF_COUNT=$(find "$REPO_ROOT/.github/workflows" \( -name '*.yml' -o -name '*.yaml' \) 2>/dev/null | wc -l | tr -d ' ')
            KEY_FILES="$KEY_FILES\n| \`.github/workflows/\` | $WF_COUNT workflow(s) |"
          fi

          # Entry points
          ENTRY_POINTS=""
          for ep in "src/main.py" "main.py" "app.py" "cmd/main.go" "main.go" \
                    "src/main.ts" "src/index.ts" "src/main.tsx" "src/index.tsx" \
                    "src/pages/Index.tsx" "src/App.tsx" "src/App.ts" \
                    "server.ts" "server.js" "src/router.ts" "src/routes.ts"; do
            has_file "$ep" && ENTRY_POINTS="$ENTRY_POINTS\n- \`$ep\`" || true
          done
          [ -z "$ENTRY_POINTS" ] && ENTRY_POINTS="\n_No standard entry points detected._"

          # Environment variables from .env.example
          ENV_VARS=""
          if has_file ".env.example"; then
            DEFINED_VARS=$({ grep -E '^[A-Z_][A-Z0-9_]*=' "$REPO_ROOT/.env.example" 2>/dev/null || true; } | sed 's/=.*//')
            COMMENTED_VARS=$({ grep -E '^#\s*[A-Z_][A-Z0-9_]*=' "$REPO_ROOT/.env.example" 2>/dev/null || true; } | sed 's/^#\s*//;s/=.*//')
            DEFINED_COUNT=$({ echo "$DEFINED_VARS" | grep -c '[A-Z]' || true; })
            COMMENTED_COUNT=$({ echo "$COMMENTED_VARS" | grep -c '[A-Z]' || true; })
            if [ "$DEFINED_COUNT" -gt 0 ] || [ "$COMMENTED_COUNT" -gt 0 ]; then
              ENV_VARS="\`$DEFINED_COUNT\` active vars in \`.env.example\`\n"
              # Group vars by prefix, accumulating names per prefix
              declare -A PREFIX_MAP
              while IFS= read -r varname; do
                [ -z "$varname" ] && continue
                PREFIX=$(echo "$varname" | cut -d'_' -f1)
                PREFIX_MAP["$PREFIX"]="${PREFIX_MAP[$PREFIX]:-} \`$varname\`"
              done <<< "$DEFINED_VARS"
              for pfx in $(echo "${!PREFIX_MAP[@]}" | tr ' ' '\n' | sort); do
                ENV_VARS="$ENV_VARS\n- **${pfx}_\***:$(echo "${PREFIX_MAP[$pfx]}")"
              done
              unset PREFIX_MAP
              if [ "$COMMENTED_COUNT" -gt 0 ]; then
                SECRET_LIST=$(echo "$COMMENTED_VARS" | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
                ENV_VARS="$ENV_VARS\n- **Secrets** (set via CI or Supabase vault): \`$SECRET_LIST\`"
              fi
            fi
          fi
          [ -z "$ENV_VARS" ] && ENV_VARS="\n_No \`.env.example\` found._"

          # Database tables from Supabase migrations
          DB_TABLES=""
          if has_dir "supabase/migrations"; then
            TABLE_NAMES=$({ grep -rh 'CREATE TABLE IF NOT EXISTS' \
                  "$REPO_ROOT/supabase/migrations/" 2>/dev/null || true; } | \
                grep -v 'PARTITION OF' | \
                sed 's/.*CREATE TABLE IF NOT EXISTS "public"\."//;s/.*CREATE TABLE IF NOT EXISTS public\.//;s/[" (].*//' | \
                grep -E '^[a-z_][a-z0-9_]*$' | \
                sort -u | head -40 || true)
            TABLE_COUNT=$({ echo "$TABLE_NAMES" | grep -c '[a-z]' || true; })
            if [ "$TABLE_COUNT" -gt 0 ]; then
              TABLE_LIST=$(echo "$TABLE_NAMES" | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
              DB_TABLES="**$TABLE_COUNT tables** from \`supabase/migrations/\`:\n\n\`$TABLE_LIST\`"
            fi
          fi
          [ -z "$DB_TABLES" ] && DB_TABLES="\n_No Supabase migrations found._"

          # Architecture patterns
          PATTERNS=""
          TENANT_DIRS=""
          has_dir "src" && TENANT_DIRS="$REPO_ROOT/src"
          has_dir "lib" && TENANT_DIRS="$TENANT_DIRS $REPO_ROOT/lib"
          if [ -n "$TENANT_DIRS" ]; then
            # shellcheck disable=SC2086
            TH=$({ grep -rl 'tenant_id' $TENANT_DIRS 2>/dev/null || true; } | wc -l | tr -d ' ')
            [ "$TH" -gt 0 ] && PATTERNS="$PATTERNS\n- **Multi-tenant**: \`tenant_id\` in $TH+ files" || true
          fi
          if [ -n "$DEPS" ]; then
            has_dep "$DEPS" "zustand"              && PATTERNS="$PATTERNS\n- **State**: Zustand"         || true
            has_dep "$DEPS" "@reduxjs/toolkit"     && PATTERNS="$PATTERNS\n- **State**: Redux Toolkit"   || true
            has_dep "$DEPS" "@tanstack/react-query"&& PATTERNS="$PATTERNS\n- **Data fetching**: TanStack Query" || true
            has_dep "$DEPS" "swr"                  && PATTERNS="$PATTERNS\n- **Data fetching**: SWR"     || true
          fi
          if [ -n "$ALL_DEPS" ]; then
            has_dep "$ALL_DEPS" "vitest"           && PATTERNS="$PATTERNS\n- **Testing**: Vitest"        || true
            has_dep "$ALL_DEPS" "jest"             && PATTERNS="$PATTERNS\n- **Testing**: Jest"          || true
            has_dep "$ALL_DEPS" "@playwright/test" && PATTERNS="$PATTERNS\n- **Testing**: Playwright"    || true
          fi
          if [ -n "$DEPS" ]; then
            has_dep "$DEPS" "@supabase/auth-helpers-react" && PATTERNS="$PATTERNS\n- **Auth**: Supabase Auth" || true
            has_dep "$DEPS" "next-auth"                    && PATTERNS="$PATTERNS\n- **Auth**: NextAuth.js"   || true
          fi
          if has_dir "src" && [ -z "$(echo "$PATTERNS" | grep 'Auth')" ]; then
            AH=$({ grep -rl 'supabase\.auth\.' "$REPO_ROOT/src" 2>/dev/null || true; } | wc -l | tr -d ' ')
            [ "$AH" -gt 0 ] && PATTERNS="$PATTERNS\n- **Auth**: Supabase Auth (via supabase-js)" || true
          fi

          # Dependencies
          DEP_SUMMARY=""
          if has_file "package.json"; then
            DC=$(jq_file "package.json" '(.dependencies // {}) | length')
            DDC=$(jq_file "package.json" '(.devDependencies // {}) | length')
            DEP_SUMMARY="- **npm**: $DC dependencies, $DDC devDependencies"
            NOTABLE=$(jq_file "package.json" '(.dependencies // {}) | keys[] | select(test("^(react$|react-dom$|react-router|vue$|next$|express$|fastify$|@nestjs/|@supabase/|prisma$|mongoose$|^pg$|^redis$|stripe$|@sentry/react$|tailwindcss$|zustand$|@reduxjs/|@tanstack/react-query$|@trpc/|zod$|i18next$|hono$|drizzle-orm$)"))' | head -15 | sed 's/^/  - /' || true)
            [ -n "$NOTABLE" ] && DEP_SUMMARY="$DEP_SUMMARY\n- **Notable**: \n$NOTABLE" || true
          fi
          has_file "requirements.txt" && DEP_SUMMARY="$DEP_SUMMARY\n- **pip**: $(grep -cE '^\s*[a-zA-Z]' "$REPO_ROOT/requirements.txt" 2>/dev/null || echo 0) packages" || true
          has_file "go.mod"           && DEP_SUMMARY="$DEP_SUMMARY\n- **Go modules**: $({ grep -c 'require' "$REPO_ROOT/go.mod" 2>/dev/null || echo 0; }) deps" || true
          if has_file "pyproject.toml" && ! has_file "requirements.txt"; then
            PY_DEP_COUNT=$(awk '/^\[project\]$/{p=1}/^\[/{if(!/^\[project\]/)p=0}p&&/^dependencies/{d=1}/d&&/\]/{d=0}d&&/^\s*"[a-zA-Z]/{c++}END{print c+0}' "$REPO_ROOT/pyproject.toml" 2>/dev/null || echo 0)
            NOTABLE_PY=$(awk '/^\[project\]$/{p=1}/^\[/{if(!/^\[project\]/)p=0}p&&/^dependencies/{d=1}/d&&/\]/{d=0}d&&/^\s*"[a-zA-Z]/{pkg=$0;gsub(/^[ \t]*"/,"",pkg);gsub(/["><=,; \t].*/,"",pkg);if(pkg~/^(fastapi|anthropic|supabase|pydantic|uvicorn|openai|langchain|httpx|sqlalchemy|celery|redis|boto3|requests|aiohttp|pytest|django|flask)$/)print "  - "pkg}' "$REPO_ROOT/pyproject.toml" 2>/dev/null || true)
            [ "$PY_DEP_COUNT" -gt 0 ] && DEP_SUMMARY="$DEP_SUMMARY\n- **pyproject.toml**: $PY_DEP_COUNT dependencies" || true
            [ -n "$NOTABLE_PY" ] && DEP_SUMMARY="$DEP_SUMMARY\n- **Notable Python packages**:\n$NOTABLE_PY" || true
          fi

          # ── Persona ────────────────────────────────────────────────────────────
          PERSONA_TYPE="software project"
          if has_dep "$DEPS" "react" 2>/dev/null && { has_dep "$DEPS" "@supabase/supabase-js" 2>/dev/null || has_dir "supabase"; }; then
            PERSONA_TYPE="React SPA with Supabase backend"
          elif has_dep "$DEPS" "react" 2>/dev/null && has_dep "$DEPS" "next" 2>/dev/null; then
            PERSONA_TYPE="Next.js full-stack application"
          elif has_dep "$DEPS" "react" 2>/dev/null; then
            PERSONA_TYPE="React frontend SPA"
          elif echo "${FRAMEWORKS[*]:-}" | grep -qi "FastAPI"; then
            PERSONA_TYPE="Python FastAPI backend service"
          elif echo "${FRAMEWORKS[*]:-}" | grep -qi "Django"; then
            PERSONA_TYPE="Python Django application"
          elif echo "${LANGUAGES[*]:-}" | grep -q "Go"; then
            PERSONA_TYPE="Go service/agent"
          elif echo "${LANGUAGES[*]:-}" | grep -q "Python"; then
            PERSONA_TYPE="Python backend service"
          fi

          # Architecture context — auto-detected special patterns
          PERSONA_ARCH=""
          if { grep -rl 'navigate-to-section\|VALID_SECTIONS' "$REPO_ROOT/src" 2>/dev/null || true; } | grep -q .; then
            PERSONA_ARCH="$PERSONA_ARCH\n- **Navigation:** Section-based (NOT URL routing) — navigate with \`window.dispatchEvent(new CustomEvent('navigate-to-section', { detail: { section: 'name' } }))\`; sections stay mounted (\`display:none\` when inactive)"
          fi
          if { ls "$REPO_ROOT/src/hooks" 2>/dev/null | grep -q 'useUserRole'; }; then
            PERSONA_ARCH="$PERSONA_ARCH\n- **Roles:** \`user\` → LiteDashboard only | \`admin\`/\`superadmin\` → full SPA | \`platform_owner\` → + platform management"
          fi
          if has_file "src/utils/featureGates.ts"; then
            PERSONA_ARCH="$PERSONA_ARCH\n- **Feature gating:** Subscription-plan based (\`trial|starter|professional|enterprise\`) via \`useFeatureGate('key')\` or \`checkFeatureAccess(key, plan)\` from \`src/utils/featureGates.ts\`"
          fi
          if has_file "src/utils/errorHandler.ts"; then
            PERSONA_ARCH="$PERSONA_ARCH\n- **Error handling:** Use \`handleError(error, { context, showToast })\` and \`handleSuccess(msg)\` from \`src/utils/errorHandler.ts\`"
          fi
          FUNC_COUNT=$({ ls "$REPO_ROOT/supabase/functions" 2>/dev/null || true; } | { grep -v '\.sh$' || true; } | wc -l | tr -d ' ')
          [ "${FUNC_COUNT:-0}" -gt 5 ] && PERSONA_ARCH="$PERSONA_ARCH\n- **Edge Functions:** $FUNC_COUNT functions in \`supabase/functions/\` (Deno runtime, called via \`supabase.functions.invoke()\`)"
          if has_file "go.mod"; then
            MOD_NAME=$(grep '^module ' "$REPO_ROOT/go.mod" 2>/dev/null | awk '{print $2}' || true)
            [ -n "$MOD_NAME" ] && PERSONA_ARCH="$PERSONA_ARCH\n- **Go module:** \`$MOD_NAME\`"
          fi

          # Coding rules
          PERSONA_ALWAYS=""
          PERSONA_NEVER="\n- Never invent file paths, function names, hook names, or table names — always verify in the codebase first\n- Never silently swallow errors — surface them via the project's error handler"

          if has_dep "$ALL_DEPS" "typescript" 2>/dev/null; then
            PERSONA_ALWAYS="$PERSONA_ALWAYS\n- Use TypeScript for every new file; never add plain \`.js\` alongside \`.ts\`"
          fi
          TS_STRICT=0
          { has_file "tsconfig.json" && grep -qE '"strict"|noImplicitAny|strictNullChecks' "$REPO_ROOT/tsconfig.json" && TS_STRICT=1; } || true
          { has_file "tsconfig.app.json" && grep -qE '"strict"|noImplicitAny|strictNullChecks' "$REPO_ROOT/tsconfig.app.json" && TS_STRICT=1; } || true
          if [ "$TS_STRICT" -gt 0 ]; then
            PERSONA_ALWAYS="$PERSONA_ALWAYS\n- Strict TypeScript: every value must be explicitly typed; use \`unknown\` instead of \`any\`"
            PERSONA_NEVER="$PERSONA_NEVER\n- Never use \`any\` — the tsconfig has strict mode enabled"
          fi
          if echo "$PATTERNS" | grep -q 'Multi-tenant' 2>/dev/null; then
            PERSONA_ALWAYS="$PERSONA_ALWAYS\n- Include \`tenant_id\` in every database query — RLS is enforced at PostgreSQL level"
            PERSONA_NEVER="$PERSONA_NEVER\n- Never omit \`tenant_id\` from queries — RLS will silently return wrong data or nothing"
          fi
          if echo "$PATTERNS" | grep -q 'Auth' 2>/dev/null; then
            PERSONA_ALWAYS="$PERSONA_ALWAYS\n- Use the project's auth hooks/context for all auth checks, never roll your own"
            PERSONA_NEVER="$PERSONA_NEVER\n- Never hard-code user IDs or bypass auth guards"
          fi
          if has_dep "$DEPS" "zod" 2>/dev/null; then
            PERSONA_ALWAYS="$PERSONA_ALWAYS\n- Validate all external/user data with Zod schemas; use \`zodResolver\` with react-hook-form"
          fi
          if has_dep "$DEPS" "@tanstack/react-query" 2>/dev/null; then
            PERSONA_ALWAYS="$PERSONA_ALWAYS\n- Use TanStack Query (\`useQuery\`/\`useMutation\`) for all server state — never fetch into \`useState\`"
            PERSONA_NEVER="$PERSONA_NEVER\n- Never use \`useEffect\` + \`fetch\` when TanStack Query can handle it"
          fi
          if has_dep "$DEPS" "zustand" 2>/dev/null; then
            PERSONA_ALWAYS="$PERSONA_ALWAYS\n- Use Zustand stores in \`src/stores/\` for client-side global state"
          fi
          if has_dep "$DEPS" "@supabase/supabase-js" 2>/dev/null; then
            PERSONA_ALWAYS="$PERSONA_ALWAYS\n- Edge Functions: call via \`supabase.functions.invoke()\`, always check \`error\` AND \`data?.success\`"
          fi
          if has_dep "$ALL_DEPS" "i18next" 2>/dev/null || has_dep "$DEPS" "react-i18next" 2>/dev/null; then
            PERSONA_ALWAYS="$PERSONA_ALWAYS\n- Wrap every user-visible string in \`t('key')\`; add to \`src/i18n/locales/\` if new"
            PERSONA_NEVER="$PERSONA_NEVER\n- Never hard-code UI text strings — always use \`t('key')\`"
          fi
          if echo "${FRAMEWORKS[*]:-}" | grep -qi "FastAPI"; then
            PERSONA_ALWAYS="$PERSONA_ALWAYS\n- All route handlers must be \`async\`; model all I/O with Pydantic"
            PERSONA_NEVER="$PERSONA_NEVER\n- Never write synchronous FastAPI route handlers or use bare dicts for request/response"
          fi
          if echo "${LANGUAGES[*]:-}" | grep -q "Go"; then
            PERSONA_ALWAYS="$PERSONA_ALWAYS\n- Handle every \`error\` return explicitly — wrap with context using \`fmt.Errorf(\"...: %w\", err)\`"
            PERSONA_NEVER="$PERSONA_NEVER\n- Never discard Go errors with \`_\`"
          fi
          if has_dir "supabase/functions"; then
            PERSONA_ALWAYS="$PERSONA_ALWAYS\n- Edge Functions run on Deno — use \`Deno.serve()\`, import from \`jsr:\`/\`npm:\`, no Node built-ins"
          fi
          if { grep -rl 'navigate-to-section\|VALID_SECTIONS' "$REPO_ROOT/src" 2>/dev/null || true; } | grep -q .; then
            PERSONA_NEVER="$PERSONA_NEVER\n- Never use \`<Link>\`, \`useNavigate()\`, or URL params for in-app navigation — use the section event"
          fi
          [ -z "$PERSONA_ALWAYS" ] && PERSONA_ALWAYS="\n- Follow existing code patterns and conventions in this repository"

          # Build main persona
          PERSONA="You are an expert developer working on **$REPO_NAME** — a $PERSONA_TYPE.\n\n> $OVERVIEW"
          [ -n "$PERSONA_ARCH" ] && PERSONA="$PERSONA\n\n### Architecture context\n$PERSONA_ARCH"
          PERSONA="$PERSONA\n\n### Always\n$PERSONA_ALWAYS\n\n### Never\n$PERSONA_NEVER"

          # ── Sub-personas: per-module context ──────────────────────────────────
          SUB_PERSONAS=""
          COMP_BASE="$REPO_ROOT/src/components"
          HOOKS_BASE="$REPO_ROOT/src/hooks"
          FUNCS_BASE="$REPO_ROOT/supabase/functions"
          SKIP_MODS="ui|common|shared|layout|forms|auth|providers|__tests__|charts|export|assets"

          # React: detect modules from src/components/ subdirectories
          if [ -d "$COMP_BASE" ] && has_file "package.json"; then
            for mod_dir in "$COMP_BASE"/*/; do
              [ -d "$mod_dir" ] || continue
              mod=$(basename "$mod_dir")
              echo "$mod" | grep -qE "^($SKIP_MODS)$" && continue
              FCOUNT=$(find "$mod_dir" -name "*.tsx" -o -name "*.ts" 2>/dev/null | wc -l | tr -d ' ')
              [ "${FCOUNT:-0}" -eq 0 ] && continue

              # Convert module name to PascalCase for hook prefix matching
              MOD_PASCAL=$(echo "$mod" | awk 'BEGIN{FS="-";OFS=""}{for(i=1;i<=NF;i++)$i=toupper(substr($i,1,1))substr($i,2)}1')
              MOD_UPPER=$(echo "$mod" | tr '[:lower:]-' '[:upper:]_' | tr -d '_')

              MOD_HOOKS=""
              if [ -d "$HOOKS_BASE" ]; then
                # Primary: hooks actually imported inside this module's components
                IMPORTED=$(grep -roh "use[A-Z][A-Za-z0-9]*" "$mod_dir" 2>/dev/null | \
                    { grep -xF -f <(ls "$HOOKS_BASE" 2>/dev/null | sed 's/\.[^.]*$//') || true; } | \
                    sort -u | head -10)
                # Fallback: name-prefix match
                NAME_MATCH=$(ls "$HOOKS_BASE" 2>/dev/null | \
                    { grep -iE "^use($mod|$MOD_PASCAL|$MOD_UPPER)[A-Z._-]" 2>/dev/null || true; } | \
                    { grep -v "README\|\.md$\|example" 2>/dev/null || true; } | \
                    sed 's/\.[^.]*$//' | sort -u | head -8)
                MOD_HOOKS=$(printf '%s\n%s' "$IMPORTED" "$NAME_MATCH" | sort -u | \
                    { grep -v '^$' || true; } | head -10 | \
                    tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
              fi

              MOD_FUNCS=""
              if [ -d "$FUNCS_BASE" ]; then
                MOD_SHORT=$(echo "$mod" | cut -d'-' -f1)
                MOD_FUNCS=$(ls "$FUNCS_BASE" 2>/dev/null | \
                    { grep -iE "^(${mod}|${MOD_SHORT})(-|$)" 2>/dev/null || true; } | \
                    { grep -v '\.sh$' 2>/dev/null || true; } | \
                    head -6 | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
              fi

              MOD_TABLES=""
              if [ -n "${TABLE_NAMES:-}" ]; then
                MOD_PREFIX=$(echo "$mod" | tr '-' '_' | tr '[:upper:]' '[:lower:]')
                MOD_TABLES=$(echo "$TABLE_NAMES" | \
                    { grep -E "^${MOD_PREFIX}(_|$)" 2>/dev/null || true; } | \
                    head -8 | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
              fi

              ENTRY="\n### \`$mod\` — \`src/components/$mod/\` ($FCOUNT files)"
              [ -n "$MOD_HOOKS" ] && ENTRY="$ENTRY\n- **Hooks:** \`$(echo "$MOD_HOOKS" | sed 's/, /\`, \`/g')\`"
              [ -n "$MOD_FUNCS" ] && ENTRY="$ENTRY\n- **Edge Functions:** \`$(echo "$MOD_FUNCS" | sed 's/, /\`, \`/g')\`"
              [ -n "$MOD_TABLES" ] && ENTRY="$ENTRY\n- **DB Tables:** \`$(echo "$MOD_TABLES" | sed 's/, /\`, \`/g')\`"
              SUB_PERSONAS="$SUB_PERSONAS$ENTRY"
            done
          fi

          # Python: detect sub-modules from src/ subdirectories
          if echo "${LANGUAGES[*]:-}" | grep -q "Python" && [ -d "$REPO_ROOT/src" ]; then
            for mod_dir in "$REPO_ROOT/src"/*/; do
              [ -d "$mod_dir" ] || continue
              mod=$(basename "$mod_dir")
              echo "$mod" | grep -qE "^(__pycache__|__init__|tests)$" && continue
              PY_COUNT=$(find "$mod_dir" -name "*.py" 2>/dev/null | wc -l | tr -d ' ')
              [ "${PY_COUNT:-0}" -eq 0 ] && continue
              PY_FILES=$(ls "$mod_dir"*.py 2>/dev/null | xargs -I{} basename {} .py | head -6 | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g' || true)
              ENTRY="\n### \`src/$mod/\` ($PY_COUNT .py files)"
              [ -n "$PY_FILES" ] && ENTRY="$ENTRY\n- **Files:** \`$(echo "$PY_FILES" | sed 's/, /\`, \`/g')\`"
              SUB_PERSONAS="$SUB_PERSONAS$ENTRY"
            done
          fi

          # Go: detect sub-packages from cmd/, internal/, pkg/
          if echo "${LANGUAGES[*]:-}" | grep -q "Go"; then
            for godir in "cmd" "internal" "pkg"; do
              [ -d "$REPO_ROOT/$godir" ] || continue
              SUBPKGS=$(ls "$REPO_ROOT/$godir" 2>/dev/null | head -10 | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
              [ -n "$SUBPKGS" ] && SUB_PERSONAS="$SUB_PERSONAS\n\n### \`$godir/\`\n- **Packages:** \`$(echo "$SUBPKGS" | sed 's/, /\`, \`/g')\`"
            done
          fi

          [ -z "$SUB_PERSONAS" ] && SUB_PERSONAS="\n_No sub-modules detected._"

          # Write output
          mkdir -p "$OUTPUT_DIR"
          printf "<!-- AUTO-GENERATED by CISECSL/org-tools -->\n<!-- Last generated: %s -->\n\n# %s\n\n## Claude Persona\n\n%b\n\n## Module Sub-Personas\n\n%b\n\n## Overview\n\n%s\n\n## Tech Stack\n\n| Category | Technologies |\n|---|---|\n| Language | %s |\n| Framework | %s |\n| Build Tool | %s |\n| Database | %s |\n| Infrastructure | %s |\n\n## Commands\n\n%b\n\n## Directory Structure\n\n\`\`\`\n%s/%b\n\`\`\`\n\n## Key Files\n\n| File | Description |\n|---|---|\n%b\n\n## Entry Points\n\n%b\n\n## Environment Variables\n\n%b\n\n## Database Tables\n\n%b\n\n## Architecture Patterns\n\n%b\n\n## Dependencies\n\n%b\n\n---\n\n*Generated by [CISECSL/org-tools](https://github.com/CISECSL/org-tools) v1.0*\n*Last updated: %s*\n" \
            "$TIMESTAMP" "$REPO_NAME" "$PERSONA" "$SUB_PERSONAS" \
            "$OVERVIEW" \
            "$LANG_STR" "$FRMK_STR" "$BILD_STR" "$DB_STR" "$INFRA_STR" \
            "$COMMANDS" "$REPO_NAME" "$DIR_TREE" \
            "$KEY_FILES" "$ENTRY_POINTS" "$ENV_VARS" "$DB_TABLES" \
            "$PATTERNS" "$DEP_SUMMARY" "$TIMESTAMP" \
            > "$OUTPUT_FILE"

          echo "✓ Generated $OUTPUT_FILE ($(wc -l < "$OUTPUT_FILE" | tr -d ' ') lines)"

      - name: Generate repomix.xml
        run: |
          # Base ignore patterns — always excluded
          IGNORE="node_modules/**,dist/**,build/**,.next/**,coverage/**,target/**,vendor/**"
          IGNORE="$IGNORE,*.lock,package-lock.json,yarn.lock,pnpm-lock.yaml"
          IGNORE="$IGNORE,*.min.js,*.min.css,*.map,*.snap"

          # If no repo-level repomix.config.json, add common generated-file exclusions
          if [ ! -f repomix.config.json ]; then
            IGNORE="$IGNORE,src/components/ui/**"
            IGNORE="$IGNORE,src/integrations/supabase/types.ts"
            IGNORE="$IGNORE,**/*.d.ts,**/__generated__/**"
          fi

          npx --yes repomix \
            --compress \
            --output .claude/repomix.xml \
            --style xml \
            --ignore "$IGNORE"

          SIZE=$(wc -c < .claude/repomix.xml | tr -d ' ')
          echo "✓ Generated .claude/repomix.xml (${SIZE} bytes)"

      - name: Install Notion dependencies
        run: npm install --prefix /tmp/notion-sync @notionhq/client @tryfabric/martian --silent

      - name: Sync to Notion
        id: notion_sync
        env:
          NOTION_API_TOKEN: ${{ secrets.NOTION_API_TOKEN }}
          NOTION_CONTEXT_PARENT_PAGE_ID: ${{ secrets.NOTION_CONTEXT_PARENT_PAGE_ID }}
          REPO_NAME: ${{ github.event.repository.name }}
          REPO_URL: ${{ github.server_url }}/${{ github.repository }}
        run: |
          cat > /tmp/notion-sync.cjs << 'JSEOF'
          const { Client } = require('/tmp/notion-sync/node_modules/@notionhq/client');
          const { markdownToBlocks } = require('/tmp/notion-sync/node_modules/@tryfabric/martian');
          const { readFileSync } = require('fs');

          const token = process.env.NOTION_API_TOKEN;
          const parentPageId = process.env.NOTION_CONTEXT_PARENT_PAGE_ID;
          const repoName = process.env.REPO_NAME;
          const repoUrl = process.env.REPO_URL;

          if (!token || !parentPageId) { console.error('Missing Notion secrets'); process.exit(1); }

          const notion = new Client({ auth: token });

          async function withRetry(fn, retries = 4) {
            for (let i = 0; i <= retries; i++) {
              try { return await fn(); }
              catch (e) {
                const transient = e.code === 'rate_limited' || (e.status >= 500 && e.status < 600);
                if (transient && i < retries) {
                  await new Promise(r => setTimeout(r, (i + 1) * 2000));
                  continue;
                }
                throw e;
              }
            }
          }

          async function findChild(parentId, title) {
            let cursor;
            do {
              const res = await withRetry(() => notion.blocks.children.list({ block_id: parentId, page_size: 100, start_cursor: cursor }));
              for (const b of res.results) {
                if (b.type === 'child_page' && b.child_page && b.child_page.title === title) return b.id;
              }
              cursor = res.has_more ? res.next_cursor : undefined;
            } while (cursor);
            return null;
          }

          async function clearPage(pageId) {
            let cursor;
            do {
              const res = await withRetry(() => notion.blocks.children.list({ block_id: pageId, page_size: 100, start_cursor: cursor }));
              for (const b of res.results) await withRetry(() => notion.blocks.delete({ block_id: b.id }));
              cursor = res.has_more ? res.next_cursor : undefined;
            } while (cursor);
          }

          async function appendBlocks(pageId, blocks) {
            for (let i = 0; i < blocks.length; i += 100) {
              await withRetry(() => notion.blocks.children.append({ block_id: pageId, children: blocks.slice(i, i + 100) }));
            }
          }

          async function main() {
            const md = readFileSync('.claude/context.md', 'utf-8').replace(/<!--[\s\S]*?-->/g, '').trim();
            let blocks;
            try { blocks = markdownToBlocks(md); }
            catch (e) { blocks = [{ object: 'block', type: 'code', code: { rich_text: [{ type: 'text', text: { content: md.slice(0, 2000) } }], language: 'markdown' } }]; }

            blocks.unshift({ object: 'block', type: 'callout', callout: { icon: { type: 'emoji', emoji: '🔗' }, rich_text: [{ type: 'text', text: { content: 'GitHub: ' + repoUrl, link: { url: repoUrl } } }] } });

            let pageId = await findChild(parentPageId, repoName);
            if (pageId) {
              await clearPage(pageId);
              await appendBlocks(pageId, blocks);
            } else {
              const page = await withRetry(() => notion.pages.create({
                parent: { page_id: parentPageId },
                properties: { title: { title: [{ type: 'text', text: { content: repoName } }] } },
                children: blocks.slice(0, 100)
              }));
              pageId = page.id;
              if (blocks.length > 100) await appendBlocks(pageId, blocks.slice(100));
            }

            const info = await withRetry(() => notion.pages.retrieve({ page_id: pageId }));
            console.log(info.url);
          }

          main().catch(function(e) { console.error(e.message); process.exit(1); });
          JSEOF
          node /tmp/notion-sync.cjs

      - name: Commit context.md
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add -f .claude/context.md .claude/repomix.xml
          if git diff --cached --quiet; then
            echo "No changes to commit"
          else
            git commit -m "docs: update auto-generated context.md and repomix.xml"
            git push
          fi
</file>

